# 环境变量模板
# 复制此文件为 .env 并填入你的真实密钥
#
# ============================================================
#  图像生成API（OpenAI / DALL·E）配置说明
# ============================================================
# 方式A：官方OpenAI（需境外信用卡，国内无法直接访问）
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_API_KEY=sk-你的官方OpenAI密钥
#
# 方式B：第三方API中转平台（推荐，无需境外信用卡）
#   1. 找一个API中转服务商（GitHub搜"OpenAI API代理"）
#   2. 充值后获取：代理BaseURL + API Key
#   3. 填入下方即可，后端代码无需改动
#
# 方式C：多备用中转（防止单平台故障）
#   除了主配置 OPENAI_BASE_URL / OPENAI_API_KEY 外，
#   还可以配置 OPENAI_BACKUP_1_BASE_URL 等备用
#
# ============================================================

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI / DALL·E / GPT-Image 图像生成
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=dall-e-3

# 备用中转平台1（可选，防止主平台故障）
# OPENAI_BACKUP_1_BASE_URL=https://xxx中转商1.com/v1
# OPENAI_BACKUP_1_API_KEY=sk-xxx
# OPENAI_BACKUP_1_MODEL=dall-e-3

# 备用中转平台2（可选）
# OPENAI_BACKUP_2_BASE_URL=https://xxx中转商2.com/v1
# OPENAI_BACKUP_2_API_KEY=sk-xxx
# OPENAI_BACKUP_2_MODEL=dall-e-3

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

API_SECRET=your-backend-secret-token-change-this
PORT=3000

MAX_DAILY_REQUESTS=200
MAX_IMAGE_REQUESTS_PER_DAY=50
